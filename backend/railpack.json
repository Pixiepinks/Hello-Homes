{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": [
    "bison",
    "re2c",
    "libcurl4-openssl-dev",
    "libonig-dev",
    "libzip-dev",
    "libpq-dev",
    "libgd-dev",
    "libreadline-dev",
    "pkg-config",
    "libssl-dev",
    "libxml2-dev",
    "zlib1g-dev",
    "libsqlite3-dev",
    "libjpeg-dev",
    "libpng-dev",
    "libwebp-dev",
    "libfreetype6-dev",
    "libonig-dev",
    "libzip-dev",
    "libpq-dev",
    "git",
    "curl",
    "unzip",
    "xz-utils"
  ],
  "packages": {
    "php": "8.3",
    "node": "22"
  },
  "steps": {
    "build": {
      "commands": [
        "...",
        "./scripts/build-frontend.sh"
      ]
    }
  },
  "deploy": {
    "startCommand": "php artisan migrate --force && php artisan serve --host=0.0.0.0 --port=${PORT:-8000}"
  }
}
